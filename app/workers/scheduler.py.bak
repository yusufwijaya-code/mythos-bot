from datetime import date, timedelta
from apscheduler.schedulers.background import BackgroundScheduler
from apscheduler.triggers.cron import CronTrigger
from loguru import logger

from config.settings import settings
from app.core.database import SessionLocal
from app.repositories.trade_repo import TradeRepository
from app.repositories.performance_repo import PerformanceRepository


# Timeframe to cron mapping (run at candle close)
TIMEFRAME_CRON = {
    "1m": {"minute": "*/1"},
    "5m": {"minute": "*/5"},
    "15m": {"minute": "*/15"},
    "1h": {"minute": "0"},
    "4h": {"minute": "0", "hour": "*/4"},
}


class BotScheduler:
    """APScheduler wrapper for running strategy on candle close."""

    def __init__(self, trading_engine):
        self.engine = trading_engine
        self.scheduler = BackgroundScheduler(timezone="UTC")

    def start(self):
        """Start the scheduler with configured timeframe."""
        tf = settings.TIMEFRAME
        cron_params = TIMEFRAME_CRON.get(tf, {"minute": "0"})

        # Main trading cycle
        self.scheduler.add_job(
            self._run_trading_cycle,
            CronTrigger(**cron_params),
            id="trading_cycle",
            name=f"Trading Cycle ({tf})",
            replace_existing=True,
        )

        # SL/TP check every minute
        self.scheduler.add_job(
            self._check_sl_tp,
            CronTrigger(minute="*/1"),
            id="sl_tp_check",
            name="SL/TP Check",
            replace_existing=True,
        )

        # Daily report at 23:55 UTC
        self.scheduler.add_job(
            self._generate_daily_report,
            CronTrigger(hour=23, minute=55),
            id="daily_report",
            name="Daily Report",
            replace_existing=True,
        )

        # Weekly report on Sunday at 23:50 UTC
        self.scheduler.add_job(
            self._generate_weekly_report,
            CronTrigger(day_of_week="sun", hour=23, minute=50),
            id="weekly_report",
            name="Weekly Report",
            replace_existing=True,
        )

        # Health check every 5 minutes
        self.scheduler.add_job(
            self._health_check,
            CronTrigger(minute="*/5"),
            id="health_check",
            name="Health Check",
            replace_existing=True,
        )

        self.scheduler.start()
        logger.info(f"Scheduler started | Timeframe: {tf} | Cron: {cron_params}")

    def stop(self):
        if self.scheduler.running:
            self.scheduler.shutdown(wait=False)
            logger.info("Scheduler stopped")

    def _run_trading_cycle(self):
        try:
            logger.info("--- Trading cycle started ---")
            self.engine.run_cycle()
        except Exception as e:
            logger.error(f"Trading cycle error: {e}")

    def _check_sl_tp(self):
        try:
            if self.engine.active:
                self.engine.check_stop_loss_take_profit()
        except Exception as e:
            logger.error(f"SL/TP check error: {e}")

    def _generate_daily_report(self):
        try:
            db = SessionLocal()
            trade_repo = TradeRepository(db)
            perf_repo = PerformanceRepository(db)

            stats = trade_repo.get_daily_stats(
                target_date=date.today(), mode=settings.TRADING_MODE
            )

            perf_repo.create_or_update(
                report_type="daily",
                report_date=date.today(),
                total_trades=stats["total_trades"],
                winning_trades=stats["winning_trades"],
                losing_trades=stats["losing_trades"],
                win_rate=stats["win_rate"],
                net_profit=stats["net_profit"],
                gross_profit=stats["gross_profit"],
                gross_loss=stats["gross_loss"],
                profit_factor=stats["profit_factor"],
                mode=settings.TRADING_MODE,
            )

            if self.engine.notifier:
                self.engine.notifier.send_daily_report(stats)

            logger.info(f"Daily report generated: {stats}")
            db.close()

        except Exception as e:
            logger.error(f"Daily report error: {e}")

    def _generate_weekly_report(self):
        try:
            db = SessionLocal()
            trade_repo = TradeRepository(db)
            perf_repo = PerformanceRepository(db)

            today = date.today()
            week_start = today - timedelta(days=7)

            from datetime import datetime
            trades = trade_repo.get_trades_between(
                datetime.combine(week_start, datetime.min.time()),
                datetime.combine(today, datetime.max.time()),
                mode=settings.TRADING_MODE,
            )

            sell_trades = [t for t in trades if t.side == "SELL" and t.pnl is not None]
            total = len(sell_trades)
            winners = [t for t in sell_trades if float(t.pnl) > 0]
            losers = [t for t in sell_trades if float(t.pnl) <= 0]
            gross_profit = sum(float(t.pnl) for t in winners)
            gross_loss = abs(sum(float(t.pnl) for t in losers))

            stats = {
                "period": f"{week_start.isoformat()} to {today.isoformat()}",
                "total_trades": total,
                "winning_trades": len(winners),
                "losing_trades": len(losers),
                "win_rate": round(len(winners) / total * 100, 2) if total else 0,
                "net_profit": round(gross_profit - gross_loss, 2),
                "gross_profit": round(gross_profit, 2),
                "gross_loss": round(gross_loss, 2),
                "profit_factor": round(
                    gross_profit / gross_loss, 4
                ) if gross_loss > 0 else 0,
                "max_drawdown": 0,
            }

            perf_repo.create_or_update(
                report_type="weekly",
                report_date=today,
                total_trades=stats["total_trades"],
                winning_trades=stats["winning_trades"],
                losing_trades=stats["losing_trades"],
                win_rate=stats["win_rate"],
                net_profit=stats["net_profit"],
                gross_profit=stats["gross_profit"],
                gross_loss=stats["gross_loss"],
                profit_factor=stats["profit_factor"],
                mode=settings.TRADING_MODE,
            )

            if self.engine.notifier:
                self.engine.notifier.send_weekly_report(stats)

            logger.info(f"Weekly report generated: {stats}")
            db.close()

        except Exception as e:
            logger.error(f"Weekly report error: {e}")

    def _health_check(self):
        """Periodic health check — send WhatsApp alert if unhealthy."""
        try:
            rm = self.engine.risk_manager
            issues = []

            # 1. Emergency stop active
            if rm.is_emergency:
                issues.append("Emergency stop is ACTIVE")

            # 2. High error rate
            if rm.error_count >= rm.max_errors // 2:
                issues.append(f"High error rate: {rm.error_count}/{rm.max_errors}")

            # 3. Balance below threshold
            balance = self.engine.get_balance()
            initial = self.engine.get_initial_balance()
            if initial > 0:
                drop_pct = (1 - balance / initial) * 100
                if drop_pct > 15:
                    issues.append(f"Balance drop: {drop_pct:.1f}% (below threshold)")

            # 4. Binance API connectivity
            try:
                price = self.engine.binance.get_ticker_price("BTCUSDT")
                if price is None:
                    issues.append("Binance API: failed to get price")
            except Exception:
                issues.append("Binance API: connection error")

            # 5. Bot unexpectedly stopped
            if not self.engine.active and not rm.is_emergency:
                # Only alert if bot was supposed to be running
                pass  # Normal state, not an issue

            # Send alert if issues found
            if issues and self.engine.notifier:
                alert_msg = (
                    f"[HEALTH ALERT]\n"
                    + "\n".join(f"- {i}" for i in issues)
                    + f"\nBalance: {balance:.2f} USDT"
                )
                self.engine.notifier.send_error(alert_msg)
                logger.warning(f"Health alert sent: {issues}")

        except Exception as e:
            logger.error(f"Health check error: {e}")
